<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Enterprise DFIR Red/Black Theme -->

    <!-- ===== COLORS ===== -->

    <!-- Base Backgrounds -->
    <Color x:Key="BlackColor">#000000</Color>
    <Color x:Key="BackgroundDeepColor">#050508</Color>
    <Color x:Key="BackgroundPrimaryColor">#0A0A0F</Color>
    <Color x:Key="BackgroundSecondaryColor">#101016</Color>
    <Color x:Key="BackgroundTertiaryColor">#181820</Color>
    <Color x:Key="SurfaceColor">#1E1E2A</Color>
    <Color x:Key="CardBackgroundColor">#14141E</Color>
    <Color x:Key="CardBorderColor">#2A1A1A</Color>

    <!-- Red Accent Family -->
    <Color x:Key="AccentPrimaryColor">#E8102D</Color>
    <Color x:Key="AccentBrightColor">#FF1744</Color>
    <Color x:Key="AccentGlowColor">#FF0055</Color>
    <Color x:Key="AccentDarkColor">#B01030</Color>
    <Color x:Key="AccentMutedColor">#801028</Color>
    <Color x:Key="AccentSubtleColor">#2A0A14</Color>

    <!-- Aliases for backward compatibility -->
    <Color x:Key="NeonRedPrimaryColor">#E8102D</Color>
    <Color x:Key="NeonRedBrightColor">#FF1744</Color>
    <Color x:Key="NeonRedGlowColor">#FF0055</Color>
    <Color x:Key="NeonRedDarkColor">#B01030</Color>
    <Color x:Key="NeonRedMutedColor">#801028</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#F0F0F5</Color>
    <Color x:Key="TextSecondaryColor">#B0B0C0</Color>
    <Color x:Key="TextMutedColor">#707088</Color>
    <Color x:Key="TextDimColor">#505060</Color>

    <!-- Status / Risk -->
    <Color x:Key="CriticalColor">#FF0022</Color>
    <Color x:Key="HighColor">#FF4400</Color>
    <Color x:Key="MediumColor">#FF8800</Color>
    <Color x:Key="LowColor">#FFCC00</Color>
    <Color x:Key="InfoColor">#0088FF</Color>
    <Color x:Key="NormalColor">#00CC66</Color>

    <!-- Semantic -->
    <Color x:Key="ErrorColor">#FF1744</Color>
    <Color x:Key="WarningColor">#FF6D00</Color>
    <Color x:Key="SuccessColor">#00E676</Color>
    <Color x:Key="InfoBlueColor">#448AFF</Color>
    <Color x:Key="PurpleColor">#9C27B0</Color>
    <Color x:Key="CyanColor">#00BCD4</Color>

    <!-- Mal/Sus -->
    <Color x:Key="MaliciousColor">#FF0022</Color>
    <Color x:Key="SuspiciousColor">#FF8800</Color>
    <Color x:Key="NormalIndicatorColor">#00CC66</Color>

    <!-- Border -->
    <Color x:Key="BorderColor">#2A1A1A</Color>
    <Color x:Key="BorderLightColor">#3D2020</Color>

    <!-- Gradient colors -->
    <Color x:Key="NeonRedGradientStartColor">#E8102D</Color>
    <Color x:Key="NeonRedGradientEndColor">#B01030</Color>

    <!-- ===== SOLID BRUSHES ===== -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource BlackColor}" />
    <SolidColorBrush x:Key="BackgroundDeepBrush" Color="{StaticResource BackgroundDeepColor}" />
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimaryColor}" />
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}" />
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="{StaticResource BackgroundTertiaryColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}" />

    <!-- Red family (new names) -->
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentBrightBrush" Color="{StaticResource AccentBrightColor}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}" />
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}" />

    <!-- Red family (old aliases) -->
    <SolidColorBrush x:Key="NeonRedPrimaryBrush" Color="{StaticResource NeonRedPrimaryColor}" />
    <SolidColorBrush x:Key="NeonRedBrightBrush" Color="{StaticResource NeonRedBrightColor}" />
    <SolidColorBrush x:Key="NeonRedGlowBrush" Color="{StaticResource NeonRedGlowColor}" />
    <SolidColorBrush x:Key="NeonRedDarkBrush" Color="{StaticResource NeonRedDarkColor}" />
    <SolidColorBrush x:Key="NeonRedMutedBrush" Color="{StaticResource NeonRedMutedColor}" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}" />

    <!-- Status / Risk -->
    <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource CriticalColor}" />
    <SolidColorBrush x:Key="HighBrush" Color="{StaticResource HighColor}" />
    <SolidColorBrush x:Key="MediumBrush" Color="{StaticResource MediumColor}" />
    <SolidColorBrush x:Key="LowBrush" Color="{StaticResource LowColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="NormalBrush" Color="{StaticResource NormalColor}" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="InfoBlueBrush" Color="{StaticResource InfoBlueColor}" />
    <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource PurpleColor}" />
    <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanColor}" />

    <!-- Mal/Sus -->
    <SolidColorBrush x:Key="MaliciousBrush" Color="{StaticResource MaliciousColor}" />
    <SolidColorBrush x:Key="SuspiciousBrush" Color="{StaticResource SuspiciousColor}" />
    <SolidColorBrush x:Key="NormalIndicatorBrush" Color="{StaticResource NormalIndicatorColor}" />

    <!-- Border -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}" />

    <Color x:Key="BorderSubtleColor">#1A1010</Color>

    <!-- ===== GRADIENT BRUSHES ===== -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AccentPrimaryColor}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentDarkColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource BackgroundSecondaryColor}" Offset="0"/>
        <GradientStop Color="{StaticResource BackgroundDeepColor}" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="NeonRedGradient" Color="{StaticResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="NeonRedGlowGradient" Color="{StaticResource AccentGlowColor}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />

</ResourceDictionary>
