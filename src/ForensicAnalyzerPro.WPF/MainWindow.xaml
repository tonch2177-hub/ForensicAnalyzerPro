<Window x:Class="ForensicAnalyzerPro.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="480" Height="640"
        ResizeMode="NoResize"
        Topmost="True"
        Icon="Resources/logo.jpg">

    <Window.Resources>
        <Storyboard x:Key="BorderPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="0.9" Duration="0:0:2"/>
        </Storyboard>
        <Storyboard x:Key="SpinIcon" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:2"/>
        </Storyboard>
        <Storyboard x:Key="GlowPulse" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" From="#801028" To="#E8102D" Duration="0:0:1.5"/>
        </Storyboard>

        <VisualBrush x:Key="GridPattern" TileMode="Tile" Stretch="None" Viewport="0,0,40,40" ViewportUnits="Absolute">
            <VisualBrush.Visual>
                <Rectangle Width="40" Height="40" Stroke="#1A1A2A" StrokeThickness="0.5"/>
            </VisualBrush.Visual>
        </VisualBrush>
    </Window.Resources>

    <Grid>
        <Border Margin="16" Background="Transparent" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="60" ShadowDepth="0" Opacity="0.4" Color="#E8102D"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="20"
                Background="#0A0A12"
                BorderBrush="#2A1A1A"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Rectangle Fill="#08000000" Opacity="0.15">
                    <Rectangle.Effect>
                        <DropShadowEffect BlurRadius="0"/>
                    </Rectangle.Effect>
                </Rectangle>

                <Rectangle Fill="{StaticResource GridPattern}" Opacity="0.15"/>

                <Border Height="2" VerticalAlignment="Top" Background="{StaticResource AccentGradient}" Opacity="0.8"/>

                <Path Data="M0,40 L0,0 L40,0" Stroke="#E8102D" StrokeThickness="2" Opacity="0.4" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12,12,0,0"/>
                <Path Data="M440,0 L480,0 L480,40" Stroke="#E8102D" StrokeThickness="2" Opacity="0.4" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,12,12,0"/>

                <!-- ============================================================
                     STATE 0: PIN ENTRY
                     ============================================================ -->
                <Grid Visibility="{Binding CurrentState, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=PinEntry}"
                      Margin="36,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo / Shield -->
                    <Border Grid.Row="0" Width="64" Height="64" CornerRadius="32"
                            Background="#12101A" BorderBrush="#E8102D" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.5" Color="#E8102D"/>
                        </Border.Effect>
                        <TextBlock Text="FA" FontSize="26" FontWeight="Bold"
                                   Foreground="#E8102D"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title -->
                    <TextBlock Grid.Row="1" Text="SCAN VERIFICATION"
                               FontSize="18" FontWeight="Bold" Foreground="#F0F0F5"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Row="2" Text="Enter the authorized PIN to begin forensic analysis"
                               FontSize="11" Foreground="#707088"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="20,4,20,16"/>

                    <!-- PIN Input -->
                    <Border Grid.Row="3" Background="#10101A"
                            BorderBrush="#E8102D" BorderThickness="2" CornerRadius="10"
                            Padding="16,12" Margin="20,0,20,6">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                         From="#801028" To="#E8102D" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <TextBox Text="{Binding Pin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#FF1744"
                                 FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                 CaretBrush="#FF1744"
                                 MaxLength="4" x:Name="PinInput"
                                 PreviewTextInput="PinInput_PreviewTextInput"/>
                    </Border>

                    <!-- Error / Status -->
                    <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}"
                               Foreground="#FF1744" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Grid.Row="4" Text="{Binding StatusMessage}"
                               Foreground="#22C55E" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>

                    <!-- Start Button -->
                    <Button Grid.Row="5" Content="START FORENSIC SCAN"
                            Command="{Binding StartScanCommand}"
                            Height="44" FontSize="12" FontWeight="Bold" 
                            Margin="20,16,20,0"
                            Background="Transparent" BorderBrush="#E8102D" BorderThickness="2"
                            Foreground="#E8102D" Cursor="Hand"
                            IsDefault="True">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.3" Color="#E8102D"/>
                        </Button.Effect>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#15E8102D" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="Transparent" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>

                    <!-- Footer -->
                    <TextBlock Grid.Row="9" Text="v3.0 • ForensicAnalyzer DFIR Scanner"
                               FontSize="9" Foreground="#404050" HorizontalAlignment="Center"/>
                </Grid>

                <!-- ============================================================
                     STATE 1: SCANNING
                     ============================================================ -->
                <Grid Visibility="{Binding CurrentState, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Scanning}"
                      Margin="36,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Spinner -->
                    <Border Grid.Row="0" Width="56" Height="56" CornerRadius="28"
                            Background="#12101A" BorderBrush="#E8102D" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.RenderTransform>
                            <RotateTransform CenterX="28" CenterY="28"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SpinIcon}"/>
                            </EventTrigger>
                        </Border.Triggers>
                        <Viewbox Width="24" Height="24">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12 2L2 7v6c0 5.5 5.1 9.6 10 11 4.9-1.4 10-5.5 10-11V7l-10-5z" Fill="#E8102D" Stroke="#E8102D" StrokeThickness="0.5"/>
                                <Path Data="M12 8v4M12 16h.01" Stroke="#0A0A12" StrokeThickness="2"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!-- Current scan phase -->
                    <TextBlock Grid.Row="1" Text="{Binding CurrentArtifactName}"
                               FontSize="14" FontWeight="SemiBold" Foreground="#F0F0F5"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Progress bar container -->
                    <Border Grid.Row="2" Height="6" CornerRadius="3"
                            Background="#1A1A2A"
                            Margin="10,0,10,10">
                        <Border x:Name="ProgressFill"
                                Width="{Binding ScanProgress, Converter={StaticResource ProgressToWidthConverter}, ConverterParameter=408}"
                                Height="6" CornerRadius="3"
                                HorizontalAlignment="Left">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#801028" Offset="0"/>
                                    <GradientStop Color="#E8102D" Offset="0.5"/>
                                    <GradientStop Color="#FF1744" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>

                    <!-- Progress percentage -->
                    <Grid Grid.Row="3" Margin="10,0,10,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ScanPercentage}"
                                   FontSize="28" FontWeight="Bold" Foreground="#E8102D"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalItems, StringFormat={}{0} items analyzed}"
                                   FontSize="11" Foreground="#505060"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Estimated time -->
                    <TextBlock Grid.Row="4" Text="{Binding EstimatedTime}"
                               FontSize="11" Foreground="#707088"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>

                    <!-- Cancel -->
                    <Button Grid.Row="5" Content="CANCEL"
                            Click="CancelButton_Click"
                            Background="Transparent" Foreground="#505060" FontSize="10"
                            BorderThickness="1" BorderBrush="#2A1A1A"
                            HorizontalAlignment="Center" Cursor="Hand"
                            Height="30" Width="100" Margin="0,16,0,0"/>

                    <!-- Glow effect -->
                    <Rectangle Grid.Row="7" Height="120" VerticalAlignment="Bottom"
                               Fill="#0CE8102D" Margin="-36,0,-36,-24"/>
                </Grid>

                <!-- ============================================================
                     STATE 2: COMPLETE
                     ============================================================ -->
                <Grid Visibility="{Binding CurrentState, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Complete}"
                      Margin="36,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Success checkmark -->
                    <Border Grid.Row="0" Width="72" Height="72" CornerRadius="36"
                            Background="#0E1A0E" BorderBrush="#22C55E" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#22C55E"/>
                        </Border.Effect>
                        <TextBlock Text="✓" FontSize="36" FontWeight="Bold"
                                   Foreground="#22C55E"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title -->
                    <TextBlock Grid.Row="1" Text="SCAN COMPLETE"
                               FontSize="22" FontWeight="Bold" Foreground="#22C55E"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Row="2" Text="Forensic analysis finished successfully"
                               FontSize="12" Foreground="#707088"
                               HorizontalAlignment="Center" Margin="0,4,0,8"/>

                    <!-- Session info -->
                    <Border Grid.Row="3" Background="#10101A" BorderBrush="#1A1A2A" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" Margin="20,0,20,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="11" Foreground="#505060">
                                <Run Text="Session:"/>
                                <Run Text="{Binding SessionId}" FontFamily="Consolas" Foreground="#F0F0F5" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock Grid.Column="1" Text="{Binding TotalItems, StringFormat={}{0} items}"
                                       FontSize="11" Foreground="#22C55E" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <!-- Stats row -->
                    <Grid Grid.Row="4" Margin="20,0,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0E101A" BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="8" Padding="12,10">
                            <TextBlock FontSize="12" Foreground="#E8102D" FontWeight="Bold" HorizontalAlignment="Center"
                                       Text="{Binding ScanProgress, StringFormat={}{0}%}"/>
                        </Border>
                        <Border Grid.Column="2" Background="#0E101A" BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="8" Padding="12,10">
                            <TextBlock FontSize="12" Foreground="#F0F0F5" FontWeight="Bold" HorizontalAlignment="Center"
                                       Text="{Binding TotalItems, StringFormat={}{0} items}"/>
                        </Border>
                        <Border Grid.Column="4" Background="#0E101A" BorderBrush="#1A1A2A" BorderThickness="1" CornerRadius="8" Padding="12,10">
                            <TextBlock FontSize="12" Foreground="#22C55E" FontWeight="Bold" HorizontalAlignment="Center" Text="OK"/>
                        </Border>
                    </Grid>

                    <!-- Close countdown -->
                    <TextBlock Grid.Row="8" Text="{Binding CloseCountdown}"
                               FontSize="10" Foreground="#404050"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
