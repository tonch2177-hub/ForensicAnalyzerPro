<Window x:Class="MickyAc.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="720" Height="520"
        ResizeMode="NoResize"
        Topmost="True"
        Icon="Resources/logo.jpg">

    <Window.Resources>
        <Storyboard x:Key="SpinIcon" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:2"/>
        </Storyboard>
        <Storyboard x:Key="PulseRed" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="0.8" Duration="0:0:1.5"/>
        </Storyboard>
        <Storyboard x:Key="VerifiedFade">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="ShrinkToScan">
            <DoubleAnimation Storyboard.TargetProperty="Width" From="720" To="720" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="ScanSweep" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(TranslateTransform.X)" From="-400" To="1200" Duration="0:0:2.5"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0.25" Duration="0:0:1" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="NodePulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.Opacity)" From="0.2" To="0.8" Duration="0:0:1.2"/>
            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleX)" From="0.85" To="1.15" Duration="0:0:1.2"/>
            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleY)" From="0.85" To="1.15" Duration="0:0:1.2"/>
        </Storyboard>

        <VisualBrush x:Key="GridPattern" TileMode="Tile" Stretch="None" Viewport="0,0,40,40" ViewportUnits="Absolute">
            <VisualBrush.Visual>
                <Rectangle Width="40" Height="40" Stroke="#1A1A2A" StrokeThickness="0.5"/>
            </VisualBrush.Visual>
        </VisualBrush>
    </Window.Resources>

    <Grid>
        <Border Margin="16" Background="Transparent" CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="60" ShadowDepth="0" Opacity="0.35" Color="#ff1f3d"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="16"
                Background="#090909"
                BorderBrush="#1A1A1A"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Rectangle Fill="#05000000" Opacity="0.12"/>
                <Rectangle Fill="{StaticResource GridPattern}" Opacity="0.12"/>
                <Border Height="2" VerticalAlignment="Top" Background="#ff1f3d" Opacity="0.85"/>

                <!-- ============================================================
                     STATE 0: PIN ENTRY — Horizontal Layout
                     ============================================================ -->
                <Grid Visibility="{Binding CurrentState, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=PinEntry}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Logo + Brand -->
                    <Border Grid.Column="0" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="0,0,1,0">
                        <Grid VerticalAlignment="Center" Margin="0,0,0,40">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- MA Logo Shield -->
                            <Border Grid.Row="0" Width="72" Height="72" CornerRadius="36"
                                    Background="#0D0A0A" BorderBrush="#ff1f3d" BorderThickness="1.5"
                                    HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="#ff1f3d"/>
                                </Border.Effect>
                                <TextBlock Text="MA" FontSize="28" FontWeight="Bold"
                                           Foreground="#ff1f3d"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- MICKY.AC -->
                            <TextBlock Grid.Row="1" Text="MICKY" FontSize="24" FontWeight="Bold"
                                       Foreground="#ffffff" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Text=".AC" FontSize="18" FontWeight="Bold"
                                       Foreground="#ff1f3d" HorizontalAlignment="Center" Margin="0,-4,0,0"/>

                            <TextBlock Grid.Row="3" Text="Forensic Investigation Platform"
                                       FontSize="10" Foreground="#666666"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </Grid>
                    </Border>

                    <!-- RIGHT: PIN Panel -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
                        <TextBlock Text="SCAN VERIFICATION" FontSize="16" FontWeight="Bold"
                                   Foreground="#ffffff" HorizontalAlignment="Center"/>
                        <TextBlock Text="Enter authorised PIN" FontSize="11" Foreground="#666666"
                                   HorizontalAlignment="Center" Margin="0,4,0,20"/>

                        <!-- PIN Input -->
                        <Border Background="#0D0D0D" BorderBrush="#ff1f3d" BorderThickness="2"
                                CornerRadius="8" Padding="16,10" Margin="20,0,20,6">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                             From="#801028" To="#ff1f3d" Duration="0:0:1.2" AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <TextBox Text="{Binding Pin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#ff1f3d" FontSize="32" FontWeight="Bold" FontFamily="Consolas"
                                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                     CaretBrush="#ff1f3d" MaxLength="4" x:Name="PinInput"
                                     PreviewTextInput="PinInput_PreviewTextInput"/>
                        </Border>

                        <!-- Error / Status -->
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#ff1f3d" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#00d26a" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>

                        <!-- Verified overlay (shown after successful validation) -->
                        <Border x:Name="VerifiedOverlay" Visibility="Collapsed" Background="#0A1A0A"
                                BorderBrush="#00d26a" BorderThickness="1" CornerRadius="8" Padding="14,10"
                                Margin="20,12,20,0">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource VerifiedFade}"/>
                                </EventTrigger>
                            </Border.Triggers>
                            <StackPanel>
                                <TextBlock Text="SESSION VERIFIED" FontSize="14" FontWeight="Bold"
                                           Foreground="#00d26a" HorizontalAlignment="Center"/>
                                <TextBlock Text="Initialising scan engine..." FontSize="10" Foreground="#666666"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- VERIFY Button -->
                        <Button Content="VERIFY PIN"
                                Command="{Binding StartScanCommand}"
                                Height="42" FontSize="12" FontWeight="Bold"
                                Margin="20,16,20,0"
                                Background="Transparent" BorderBrush="#ff1f3d" BorderThickness="1.5"
                                Foreground="#ff1f3d" Cursor="Hand" IsDefault="True">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.3" Color="#ff1f3d"/>
                            </Button.Effect>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#14ff1f3d" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="Transparent" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>

                        <TextBlock Text="v2.0 — MICKY.AC" FontSize="9" Foreground="#404040"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ============================================================
                     STATE 1: SCANNING — Two columns: Console + Modules
                     ============================================================ -->
                <Grid Visibility="{Binding CurrentState, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Scanning}"
                      Margin="20,16,20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Progress + Console -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Analysis sweep layer -->
                        <Rectangle Grid.Row="0" Grid.RowSpan="7" Fill="#ff1f3d" Opacity="0" Height="4" VerticalAlignment="Top" IsHitTestVisible="False">
                            <Rectangle.RenderTransform><TranslateTransform X="-400"/></Rectangle.RenderTransform>
                            <Rectangle.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource ScanSweep}"/>
                                </EventTrigger>
                            </Rectangle.Triggers>
                        </Rectangle>

                        <!-- Connection nodes -->
                        <Border Grid.Row="0" Grid.RowSpan="7" IsHitTestVisible="False" Opacity="0.15">
                            <Canvas>
                                <Ellipse Width="6" Height="6" Fill="#ff1f3d" Canvas.Left="20" Canvas.Top="30" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform><ScaleTransform/></Ellipse.RenderTransform>
                                    <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard Storyboard="{StaticResource NodePulse}"/></EventTrigger></Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="4" Height="4" Fill="#ff1f3d" Canvas.Left="120" Canvas.Top="60" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform><ScaleTransform/></Ellipse.RenderTransform>
                                    <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard Storyboard="{StaticResource NodePulse}"/></EventTrigger></Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="5" Height="5" Fill="#ff1f3d" Canvas.Left="60" Canvas.Top="120" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform><ScaleTransform/></Ellipse.RenderTransform>
                                    <Ellipse.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard Storyboard="{StaticResource NodePulse}"/></EventTrigger></Ellipse.Triggers>
                                </Ellipse>
                            </Canvas>
                        </Border>

                        <!-- Scan title -->
                        <TextBlock Grid.Row="0" Text="FORENSIC ANALYSIS IN PROGRESS"
                                   FontSize="14" FontWeight="Bold" Foreground="#ffffff" Margin="0,2,0,0"/>
                        <TextBlock Grid.Row="1" Text="{Binding CurrentArtifactName}"
                                   FontSize="11" Foreground="#9a9a9a" Margin="0,2,0,16"/>

                        <!-- Progress bar -->
                        <Border Grid.Row="2" Height="5" CornerRadius="2.5" Background="#1A1A1A" Margin="0,0,0,8">
                            <Border x:Name="ProgressFill"
                                    Width="{Binding ScanProgress, Converter={StaticResource ProgressToWidthConverter}, ConverterParameter=380}"
                                    Height="5" CornerRadius="2.5" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#801028" Offset="0"/>
                                        <GradientStop Color="#ff1f3d" Offset="0.6"/>
                                        <GradientStop Color="#ff1f3d" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>

                        <!-- Percentage + items -->
                        <Grid Grid.Row="3" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ScanPercentage}"
                                       FontSize="26" FontWeight="Bold" Foreground="#ff1f3d"/>
                            <TextBlock Grid.Column="2" Text="{Binding TotalItems, StringFormat={}{0} items}"
                                       FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Live Statistics Row -->
                        <Border Grid.Row="4" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                                CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LiveFilesAnalyzed}" FontSize="16" FontWeight="Bold" Foreground="#ffffff" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Files" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LiveRegistryParsed}" FontSize="16" FontWeight="Bold" Foreground="#ffffff" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Registry" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LiveArtifactsFound}" FontSize="16" FontWeight="Bold" Foreground="#ffffff" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Artifacts" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LiveEventsProcessed}" FontSize="16" FontWeight="Bold" Foreground="#ffffff" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Events" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Console output -->
                        <Border Grid.Row="5" Background="#070707" BorderBrush="#1A1A1A" BorderThickness="1"
                                CornerRadius="6" Padding="10,8" Margin="0,0,0,6" MinHeight="90" MaxHeight="120">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0">
                                <ItemsControl ItemsSource="{Binding ConsoleLines}" Background="Transparent" BorderThickness="0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="10" FontFamily="Consolas"
                                                       Foreground="#9a9a9a" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <!-- Elapsed + Cancel -->
                        <Grid Grid.Row="6" VerticalAlignment="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Elapsed: " FontSize="10" Foreground="#666666"/>
                                <TextBlock Text="{Binding LiveElapsedTime}" FontSize="10" FontFamily="Consolas" Foreground="#9a9a9a"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="CANCEL" Click="CancelButton_Click"
                                    Background="Transparent" Foreground="#666666" FontSize="10"
                                    BorderThickness="1" BorderBrush="#2A1A1A" CornerRadius="4"
                                    Cursor="Hand" Height="26" Width="80"/>
                        </Grid>
                    </Grid>

                    <!-- RIGHT: Modules Panel -->
                    <Border Grid.Column="2" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="1"
                            CornerRadius="8" Padding="0">
                        <Grid>
                            <TextBlock Text="ACTIVE MODULES" FontSize="10" FontWeight="Bold"
                                       Foreground="#666666" Margin="14,12,14,8"
                                       HorizontalAlignment="Center"/>
                            <ItemsControl ItemsSource="{Binding Modules}"
                                          Margin="0,32,0,0"
                                          Background="Transparent" BorderThickness="0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1"
                                                Padding="12,8" Margin="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           FontSize="11" Foreground="#ffffff" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" CornerRadius="3" Padding="6,2" MinWidth="50"
                                                        Background="{Binding StatusColor}" BorderThickness="0">
                                                    <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="Bold"
                                                               Foreground="#ffffff" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ============================================================
                     STATE 2: COMPLETE
                     ============================================================ -->
                <Grid Visibility="{Binding CurrentState, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Complete}"
                      Margin="36,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Success icon -->
                    <Border Grid.Row="0" Width="64" Height="64" CornerRadius="32"
                            Background="#0A1A0A" BorderBrush="#00d26a" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.4" Color="#00d26a"/>
                        </Border.Effect>
                        <TextBlock Text="OK" FontSize="22" FontWeight="Bold" Foreground="#00d26a"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="SCAN COMPLETED"
                               FontSize="20" FontWeight="Bold" Foreground="#00d26a"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Text="Forensic analysis finished successfully — results uploaded to API"
                               FontSize="11" Foreground="#9a9a9a"
                               HorizontalAlignment="Center" Margin="0,4,0,16"/>

                    <!-- Summary cards -->
                    <Border Grid.Row="3" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1"
                            CornerRadius="8" Padding="16,14" Margin="20,0,20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="10" Foreground="#9a9a9a">Session</TextBlock>
                                <TextBlock Text="{Binding SessionId}" FontFamily="Consolas" FontSize="13"
                                           Foreground="#ffffff" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock FontSize="10" Foreground="#9a9a9a">Duration</TextBlock>
                                <TextBlock Text="{Binding ScanDuration}" FontFamily="Consolas" FontSize="13"
                                           Foreground="#ffffff" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Stat boxes -->
                    <Grid Grid.Row="4" Margin="20,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="6" Padding="8,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalItems}" FontSize="16" FontWeight="Bold" Foreground="#ff1f3d" HorizontalAlignment="Center"/>
                                <TextBlock Text="Artifacts" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="6" Padding="8,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding IocsDetected}" FontSize="16" FontWeight="Bold" Foreground="#ff8c00" HorizontalAlignment="Center"/>
                                <TextBlock Text="IOCs" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="6" Padding="8,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ScanProgress, StringFormat={}{0}%}" FontSize="16" FontWeight="Bold" Foreground="#00d26a" HorizontalAlignment="Center"/>
                                <TextBlock Text="Progress" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Background="#0A0A0A" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="6" Padding="8,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="OK" FontSize="16" FontWeight="Bold" Foreground="#00d26a" HorizontalAlignment="Center"/>
                                <TextBlock Text="Upload" FontSize="9" Foreground="#666666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Close countdown -->
                    <TextBlock Grid.Row="6" Text="{Binding CloseCountdown}"
                               FontSize="10" Foreground="#404040" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>